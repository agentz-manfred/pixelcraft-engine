{
  "name": "pixelcraft-engine",
  "version": "0.1.0",
  "description": "Lightweight pixel art engine — sprites, animations, palettes. Canvas/PNG/GIF/SVG rendering. Zero dependencies.",
  "type": "module",
  "main": "./dist/pixelcraft-engine.cjs",
  "module": "./dist/pixelcraft-engine.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pixelcraft-engine.js",
      "require": "./dist/pixelcraft-engine.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "palettes"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "playground": "vite serve playground --port 3333",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "pixel-art",
    "sprites",
    "animation",
    "canvas",
    "game-engine",
    "pixel",
    "gif",
    "png",
    "svg",
    "retro"
  ],
  "author": "AgentZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentz-manfred/pixelcraft-engine.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  }
}
